      "text": "传 真:021-58957710",
      "style": "",
      "source_kind": "paragraph",
      "source_page_start": 0,
      "source_page_end": 0,
      "start_char": 895,
      "end_char": 911,
      "region": "body"
    },
    {
      "block_id": "b00014",
